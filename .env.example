BOT_TOKEN=123456:ABC-your-telegram-bot-token
CHAT_ID=123456789
# Опционально: треки добавляются через ТГ (присылайте ссылку tracking.ozon.ru).
# Эта переменная только для первичного заполнения /data/tracks.json, если файл пуст.
TRACK_URLS=
# Дамп HTML/текста страницы в /data/debug при ошибках (0/1)
DEBUG_DUMP=0

# Опциональный прокси для Chromium — нужен, если сервер на нероссийском IP,
# а Ozon банит дата-центровые IP по antibot. Поддерживаются http://, https://, socks5://
# PROXY_SERVER=http://1.2.3.4:8080
# PROXY_USERNAME=
# PROXY_PASSWORD=
